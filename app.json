{
  "expo": {
    "name": "Jahera",
    "slug": "jahera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jahera",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "description": "Jahera - AI-powered personalized story adventures for kids. Create magical, educational stories tailored to your child's interests, family, and friends with multilingual narration.",
    "primaryColor": "#FF4B4B",
    "backgroundColor": "#FFF8E7",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "privacy": "public",
    "category": "education",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hindi.harp",
      "buildNumber": "1.0.0",
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Jahera needs microphone access for voice input features.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "Jahera uses notifications for bedtime story reminders."
      },
      "privacyManifests": {
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.hindi.harp",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.hindi.harp"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Jahera to access your microphone for voice features."
        }
      ],
      "expo-video",
      [
        "expo-notifications"
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "f64a4e9f-d17e-41be-8480-65f1565162e8"
      },
      "router": {}
    },
    "owner": "dulork"
  }
}
