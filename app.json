{
  "expo": {
    "name": "Jahera",
    "slug": "jahera",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jahera",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "description": "Jahera - AI-powered personalized story platform for families. Create magical, educational stories tailored to your family's values, interests, and goals with multilingual narration.",
    "primaryColor": "#FF4B4B",
    "backgroundColor": "#FFF8E7",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.celestial.spire",
      "buildNumber": "1.0.0",
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Jahera uses microphone access to enable voice input features for story creation.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationUsageDescription": "Jahera sends reminders for your family's story time schedule.",
        "UIBackgroundModes": ["audio"]
      },
      "privacyManifests": {
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.celestial.spire",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.jahera.kidstory"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Jahera to use your microphone for voice-powered story creation."
        }
      ],
      "expo-video",
      ["expo-notifications"],
      "@react-native-community/datetimepicker",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "f64a4e9f-d17e-41be-8480-65f1565162e8"
      },
      "router": {}
    },
    "owner": "dulork"
  }
}
