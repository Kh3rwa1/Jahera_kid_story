{
  "expo": {
    "name": "Jahera",
    "slug": "jahera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jahera",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "description": "Jahera - AI-powered personalized story adventures for kids. Create magical, educational stories tailored to your child's interests, family, and friends with multilingual narration.",
    "primaryColor": "#FF4B4B",
    "backgroundColor": "#FFF8E7",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "privacy": "public",
    "category": "education",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hindi.harp",
      "buildNumber": "1.0.0",
      "requireFullScreen": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Jahera needs microphone access for voice input features.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hindi.harp",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.hindi.harp"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Jahera to use your location to set stories in your neighbourhood.",
          "locationWhenInUsePermission": "Allow Jahera to use your location to set stories in your neighbourhood."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow Jahera to access your microphone for voice features."
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false
    },
    "extra": {
      "eas": {
        "projectId": "f64a4e9f-d17e-41be-8480-65f1565162e8"
      },
      "router": {}
    },
    "owner": "dulork"
  }
}
